---
// Themed clip-art of a "take-home companion document" — a little booklet with
// the brand mark on the cover. Used to separate the two note boxes in Consults.
// Decorative (aria-hidden); matches the pastel + line-art theme.
import { LOGO_INNER_TRANSFORM, CHAIR_PATH, ORB_PATH } from "../lib/logoPaths.js";
---
<div class="companion-doc" aria-hidden="true">
  <svg viewBox="0 0 150 150" role="presentation">
    {/* soft shadow */}
    <ellipse cx="76" cy="138" rx="46" ry="7" fill="rgba(65,54,69,0.10)" />

    {/* back page peeking out */}
    <rect x="42" y="24" width="70" height="96" rx="8" fill="#cfc6ee" opacity="0.55"
          transform="rotate(6 77 72)" />

    {/* front page */}
    <g transform="rotate(-4 70 74)">
      <rect x="34" y="20" width="72" height="100" rx="8" fill="#fffdfb"
            stroke="#413645" stroke-width="2.4" />
      {/* header band */}
      <rect x="34" y="20" width="72" height="26" rx="8" fill="#a85a76" />
      <rect x="34" y="38" width="72" height="8" fill="#a85a76" />
      {/* brand mark on the cover (scaled from the 1273x1609 logo art) */}
      <g transform="translate(48 24) scale(0.01181)">
        <g transform={LOGO_INNER_TRANSFORM}>
          <path d={CHAIR_PATH} fill="#fffdfb" />
          <path d={ORB_PATH} fill="#e6b8c6" />
        </g>
      </g>

      {/* text lines */}
      <rect x="44" y="58" width="52" height="4.5" rx="2.25" fill="#6e6172" opacity="0.55" />
      <rect x="44" y="69" width="52" height="4.5" rx="2.25" fill="#6e6172" opacity="0.4" />
      <rect x="44" y="80" width="40" height="4.5" rx="2.25" fill="#6e6172" opacity="0.4" />
      <rect x="44" y="94" width="52" height="4.5" rx="2.25" fill="#6e6172" opacity="0.4" />
      <rect x="44" y="105" width="34" height="4.5" rx="2.25" fill="#6e6172" opacity="0.4" />
    </g>

    {/* gold bookmark ribbon */}
    <path d="M96 22 L96 52 L88 44 L80 52 L80 22 Z" fill="#b98a52"
          transform="rotate(-4 70 74)" />
  </svg>
</div>

<style>
  .companion-doc {
    display: flex;
    justify-content: center;
    margin: 6px auto 2px;
  }
  .companion-doc svg {
    width: 128px;
    height: auto;
    filter: drop-shadow(0 8px 18px rgba(65, 54, 69, 0.10));
    transition: transform 0.3s ease;
  }
  .companion-doc svg:hover {
    transform: translateY(-3px) rotate(1deg);
  }
</style>
