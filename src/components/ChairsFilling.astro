---
// Decorative, on-brand animation: a row of the actual brand mark, where the
// orbs drop into their seats one by one — a literal "no empty chair."
// Uses the real logo art so it matches the mark exactly.
// Purely visual (aria-hidden), CSS-only, respects prefers-reduced-motion.
import { LOGO_VIEWBOX, LOGO_INNER_TRANSFORM, CHAIR_PATH, ORB_PATH } from "../lib/logoPaths.js";

const seats = [
  { color: "#f3c9d3", delay: "0s" },   // blush
  { color: "#cfc6ee", delay: "0.4s" }, // lilac
  { color: "#c2ddcf", delay: "0.8s" }, // mint
  { color: "#c4d8f0", delay: "1.2s" }, // sky
  { color: "#e6b8c6", delay: "1.6s" }, // light rose
];
---
<div class="chairs-band" aria-hidden="true">
  {seats.map((s) => (
    <svg class="chair-unit" viewBox={LOGO_VIEWBOX} preserveAspectRatio="xMidYMid meet" role="presentation">
      <g fill="#413645" stroke="none">
        <g transform={LOGO_INNER_TRANSFORM}><path d={CHAIR_PATH} /></g>
      </g>
      <g class="chair-person" style={`--d:${s.delay}`}>
        <g transform={LOGO_INNER_TRANSFORM}><path d={ORB_PATH} fill={s.color} /></g>
      </g>
    </svg>
  ))}
</div>

<style>
  .chairs-band {
    max-width: 1080px;
    margin: 0 auto;
    padding: 10px var(--gutter) 0;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: clamp(14px, 3.5vw, 46px);
  }
  .chair-unit {
    height: clamp(58px, 8vw, 104px);
    width: auto;
    display: block;
    overflow: visible;
  }
  .chair-person {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: seat-fill 6s ease-in-out infinite;
    animation-delay: var(--d);
  }
  /* values are in the mark's viewBox units (1273x1609) */
  @keyframes seat-fill {
    0%   { opacity: 0; transform: translateY(150px) scale(0.35); }
    10%  { opacity: 1; transform: translateY(0) scale(1.09); }
    16%  { transform: translateY(0) scale(1); }
    72%  { opacity: 1; transform: none; }
    84%  { opacity: 0; transform: translateY(110px) scale(0.5); }
    100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .chair-person { animation: none; opacity: 1; }
  }
</style>
