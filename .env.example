# Copy these into Netlify -> Site config -> Environment variables.
# Server-only vars (NO REACT_APP_ prefix) are never sent to the browser.

# --- Admin editing (required for the /admin panel to save) ---
GITHUB_TOKEN=            # fine-grained token, THIS repo only, Contents: Read & write
GITHUB_OWNER=mrichards280
GITHUB_REPO=no-empty-chair
GITHUB_BRANCH=main
ADMIN_PASSWORD=          # the password you type to log into /admin

# --- Contact form email (optional; without it, messages still log to GitHub) ---
RESEND_API_KEY=          # from resend.com, for email notifications
CONTACT_TO_EMAIL=hello@noemptychair.co

# --- Image uploads (public, safe to expose) ---
# Astro exposes browser vars with the PUBLIC_ prefix (CRA used REACT_APP_).
PUBLIC_CLOUDINARY_CLOUD_NAME=djrmz717j
PUBLIC_CLOUDINARY_UPLOAD_PRESET=noemptychair
